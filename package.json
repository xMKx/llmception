{
  "name": "llmception",
  "version": "0.1.0",
  "description": "A daemon that explores multiple implementation paths for ambiguous LLM prompts by building decision trees across parallel git worktrees",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "llmception": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "claude",
    "ai",
    "decision-tree",
    "code-generation",
    "parallel-exploration",
    "git-worktree",
    "developer-tools"
  ],
  "author": "Martin Kambla",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xMKx/llmception.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "chalk": "^5.4.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "tsx": "^4.19.4",
    "eslint": "^9.25.0",
    "@eslint/js": "^9.25.0",
    "typescript-eslint": "^8.30.1",
    "prettier": "^3.5.3",
    "@vitest/coverage-v8": "^3.1.1"
  }
}
